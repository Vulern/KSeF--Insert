{
  "name": "ksef-insert-integration",
  "version": "0.1.0",
  "description": "Integracja między KSeF (Krajowy System e-Faktur) a programem Insert (desktop)",
  "type": "module",
  "main": "dist/index.js",
  "script": "tsx",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "sync": "tsx src/index.ts sync",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ksef",
    "e-faktury",
    "insert",
    "integration",
    "csv"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "axios": "^1.6.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "csv-stringify": "^6.4.0",
    "fast-xml-parser": "^4.3.0",
    "hono": "^4.12.14",
    "iconv-lite": "^0.6.3",
    "libxmljs2": "^0.37.0",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "pino": "^8.17.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.54.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
